# GateKeeperAI ├втВмтАЭ environment template.
# Copy to `.env` and fill real values. ONLY `.env.example` is committed; `.env` is git-ignored.
# This file contains secret *names*, never real secret *values*.

# --- Audit ledger integrity (REQUIRED) ------------------------------------
# Key for the keyed-HMAC hash-chain (ADR-003). Without it an attacker who tampers
# with the ledger cannot re-forge a valid chain. Generate: `openssl rand -hex 32`.
GATEKEEPER_HMAC_KEY=

# --- Agent identity for `gatekeeper serve` (REQUIRED to serve) -------------
# Bearer token the agent presents to the stdio gateway; resolved to a Principal via
# config/identities.yaml. Use one of that file's dev tokens, or a real one in prod.
# An unset/unknown token is rejected fail-closed (the gateway refuses to serve).
GATEKEEPER_AGENT_TOKEN=

# --- LLM provider for M2 risk-scoring (NOT needed for M1) ------------------
# Default provider is Claude (see config/platform.yaml -> llm.provider).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=          # only if llm.provider=openai

# --- Upstream server credentials (only if a governed server needs one) -----
# When config/upstreams.yaml references a secret via `{ from_env: NAME }`, set NAME here (no
# GATEKEEPER_ prefix ├втВмтАЭ the name is matched as-is). The value stays here, never in upstreams.yaml.
# Example for the GitHub MCP server:
# GITHUB_TOKEN=

# --- Operator alerting (M3.4, optional) ------------------------------------
# Webhook for verify-failure / deny-spike alerts (Slack/Teams/PagerDuty-style URL).
# Lives here because such URLs routinely embed a token. Unset = alerting off.
# GATEKEEPER_ALERT_WEBHOOK=

# --- Runtime knobs (optional; override config/*.yaml defaults) -------------
# GATEKEEPER_ENV=dev
# GATEKEEPER_LOG_LEVEL=INFO
# GATEKEEPER_CONFIG_DIR=./config
